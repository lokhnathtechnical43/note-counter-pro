generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("user")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses    Expense[]
  receivables Receivable[]
  payables    Payable[]
  loans       Loan[]
  accounts    Account[]
  notes       Note[]
  plans       Plan[]
  documents   Document[]
  alarms      Alarm[]
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  category    String
  date        String
  note        String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([date])
}

model Receivable {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  fromPerson  String
  dueDate     String?
  status      String   @default("pending")
  note        String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Payable {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  toPerson    String
  dueDate     String?
  status      String   @default("pending")
  note        String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Loan {
  id              String   @id @default(cuid())
  title           String
  totalAmount     Float
  paidAmount      Float    @default(0)
  emiAmount       Float?
  interestRate    Float?
  tenure          Int?
  startDate       String
  endDate         String?
  status          String   @default("active")
  note            String?
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Account {
  id          String   @id @default(cuid())
  name        String
  type        String
  balance     Float
  note        String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Note {
  id          String   @id @default(cuid())
  title       String
  content     String
  color       String   @default("#ffffff")
  pinned      Boolean  @default(false)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([pinned])
}

model Plan {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        String
  time        String?
  priority    String   @default("medium")
  completed   Boolean  @default(false)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@index([completed])
}

model Document {
  id          String   @id @default(cuid())
  name        String
  type        String
  size        Int      @default(0)
  data        String
  category    String   @default("general")
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
}

model Alarm {
  id          String   @id @default(cuid())
  title       String
  time        String
  date        String?
  repeat      String   @default("once")
  active      Boolean  @default(true)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([active])
}
